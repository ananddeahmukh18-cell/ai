# ──────────────────────────────────────────────
# JARVIS-MAC Environment Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# Required: Anthropic API Key
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Flask secret key (change this in production)
SECRET_KEY=jarvis-mac-super-secret-2024

# Optional: Port to run on (default: 5050)
PORT=5050
